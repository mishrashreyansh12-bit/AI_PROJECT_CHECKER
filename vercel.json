{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/t/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend/assets/$1"
    },
    {
      "src": "/banner.png",
      "dest": "frontend/banner.png"
    },
    {
      "src": "/favicon.svg",
      "dest": "frontend/favicon.svg"
    },
    {
      "src": "/icons.svg",
      "dest": "frontend/icons.svg"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ]
}
